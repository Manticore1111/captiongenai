{
  "version": 2,
  "builds": [
    {
      "src": "standalone/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/generator.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/login.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/register.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/dashboard.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/upgrade.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/saved-captions.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/profile.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/settings.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/analytics.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/index.html",
      "dest": "standalone/index.html"
    },
    {
      "src": "/generator.html",
      "dest": "standalone/generator.html"
    },
    {
      "src": "/login.html",
      "dest": "standalone/login.html"
    },
    {
      "src": "/register.html",
      "dest": "standalone/register.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "standalone/dashboard.html"
    },
    {
      "src": "/upgrade.html",
      "dest": "standalone/upgrade.html"
    },
    {
      "src": "/saved-captions.html",
      "dest": "standalone/saved-captions.html"
    },
    {
      "src": "/profile.html",
      "dest": "standalone/profile.html"
    },
    {
      "src": "/settings.html",
      "dest": "standalone/settings.html"
    },
    {
      "src": "/analytics.html",
      "dest": "standalone/analytics.html"
    },
    {
      "src": "/(.*)",
      "dest": "standalone/$1"
    }
  ]
}
