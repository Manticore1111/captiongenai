{
  "version": 2,
  "buildCommand": "echo 'No build needed - static site'",
  "builds": [
    {
      "src": "standalone/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/generator.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/login.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/register.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/dashboard.html",
      "use": "@vercel/static"
    },
    {
      "src": "standalone/upgrade.html",
      "use": "@vercel/static"
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*\\.html)$",
      "dest": "standalone/$1"
    },
    {
      "src": "/(.*)",
      "dest": "standalone/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
